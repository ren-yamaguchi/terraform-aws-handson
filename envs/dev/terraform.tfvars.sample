# 下記はweb, ap, dbと異なる EC2 に対してそれぞれ別の security group を付与する時の terraform.ftvars の例です

project_name    = "handson"
environment     = "dev"

key_pair_name   = "your-key-name"      # Replace with your key pair name
common_ssh_cidr = "x.x.x.x/32"         # Replace with your global IP/32 (curl https://checkip.amazonaws.com)

# ===== Subnets =====
# Each tier has its own dedicated subnet.
subnets = {
  "web-a"  = { cidr = "10.0.1.0/24",  az = "ap-northeast-1a", type = "public" }
  "app-a"  = { cidr = "10.0.11.0/24", az = "ap-northeast-1a", type = "private" }
  "data-a" = { cidr = "10.0.21.0/24", az = "ap-northeast-1a", type = "private" }

  # The following are kept for redundancy expansion (optional). Remove if not needed.
  "web-c"  = { cidr = "10.0.2.0/24",  az = "ap-northeast-1c", type = "public" }
  "app-c"  = { cidr = "10.0.12.0/24", az = "ap-northeast-1c", type = "private" }
  "data-c" = { cidr = "10.0.22.0/24", az = "ap-northeast-1c", type = "private" }
}

# ===== Additional Security Groups =====
security_groups = {
  "web" = {
    description = "Web tier: Apache (HTTP/HTTPS) from my IP"
    ingress_rules = [
      {
        description = "HTTP from my IP"
        from_port   = 80
        to_port     = 80
        protocol    = "tcp"
        cidr_blocks = ["x.x.x.x/32"]    # Replace with your global IP/32 (same as common_ssh_cidr)
      },
      {
        description = "HTTPS from my IP"
        from_port   = 443
        to_port     = 443
        protocol    = "tcp"
        cidr_blocks = ["x.x.x.x/32"]    # Replace with your global IP/32
      }
    ]
  }

  "ap" = {
    description = "AP tier: php-fpm from VPC"
    ingress_rules = [
      {
        description = "php-fpm FastCGI from VPC"
        from_port   = 9000
        to_port     = 9000
        protocol    = "tcp"
        cidr_blocks = ["10.0.0.0/16"]
      }
    ]
  }

  "db" = {
    description = "DB tier: MariaDB from VPC"
    ingress_rules = [
      {
        description = "MariaDB/MySQL from VPC"
        from_port   = 3306
        to_port     = 3306
        protocol    = "tcp"
        cidr_blocks = ["10.0.0.0/16"]
      }
    ]
  }
}

# ===== EC2 instances =====
instances = {
  "ec2-web" = {
    instance_type       = "t3.micro"
    subnet_name         = "web-a"
    security_group_ids  = ["common", "web"]
    associate_public_ip = true
  }
  "ec2-ap" = {
    instance_type       = "t3.small"
    subnet_name         = "app-a"
    security_group_ids  = ["common", "ap"]
    associate_public_ip = false
  }
  "ec2-db" = {
    instance_type       = "t3.small"
    subnet_name         = "data-a"
    security_group_ids  = ["common", "db"]
    associate_public_ip = false
  }
}

# ===== Feature toggles =====
# NAT is required because AP and DB are in private subnets and need outbound internet
# (e.g. dnf install for installing Apache, php-fpm, MariaDB, etc.).
enable_nat = true
enable_alb = false