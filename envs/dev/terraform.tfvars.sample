project_name    = "handson"
environment     = "dev"

key_pair_name   = "your-key-name"      # 自分のキーペア名に置き換えてください
common_ssh_cidr = "x.x.x.x/32"         # 自分のグローバルIP/32に置き換えてください(確認方法: curl https://checkip.amazonaws.com)

# ===== VPC =====
# デフォルトのVPC CIDR(10.0.0.0/16)を変更したい場合はコメントを外して変更してください。
# その際、subnets[].cidr も新しいVPCの範囲に収まるように併せて更新してください。
# vpc_cidr = "172.31.0.0/16"

# ===== サブネット =====
# 各サブネットは subnet_name => { cidr, az, type } の形式で定義します。
# type は "public" または "private" を指定してください。
# 同一AZ内に複数のサブネットを定義することも可能です。
subnets = {
  "public-a"  = { cidr = "10.0.1.0/24",  az = "ap-northeast-1a", type = "public" }
#  "public-c"  = { cidr = "10.0.2.0/24",  az = "ap-northeast-1c", type = "public" }
#  "private-a" = { cidr = "10.0.11.0/24", az = "ap-northeast-1a", type = "private" }
#  "private-c" = { cidr = "10.0.12.0/24", az = "ap-northeast-1c", type = "private" }
}

# ===== 追加のセキュリティグループ(任意) =====
# "common" SG(SSHのみ)は自動的に作成されます。追加のSGはここで定義してください。
# 各EC2は instances 内の security_group_ids でSG名を参照します。
#
# 各ingressルールには cidr_blocks(IPベース)または
# source_security_groups(SGベース)のいずれか、または両方を指定できます。
# このブロック内で定義したSG名を参照可能で、"common" や自己参照も可能です。
security_groups = {
  # 例: Web層(自分のIPからのHTTP / HTTPS)
  # "web" = {
  #   description = "Web tier"
  #   ingress_rules = [
  #     { description = "HTTP",  from_port = 80,  to_port = 80,  protocol = "tcp", cidr_blocks = ["x.x.x.x/32"] },
  #     { description = "HTTPS", from_port = 443, to_port = 443, protocol = "tcp", cidr_blocks = ["x.x.x.x/32"] }
  #   ]
  # }

  # 例: AP層(web SGからのTomcatのみ)
  # "ap" = {
  #   description = "AP tier"
  #   ingress_rules = [
  #     { description = "Tomcat from web SG", from_port = 8080, to_port = 8080, protocol = "tcp", source_security_groups = ["web"] }
  #   ]
  # }

  # 例: DB層(ap SGからのPostgreSQLのみ)
  # "db" = {
  #   description = "DB tier"
  #   ingress_rules = [
  #     { description = "PostgreSQL from ap SG", from_port = 5432, to_port = 5432, protocol = "tcp", source_security_groups = ["ap"] }
  #   ]
  # }

  # 例: クラスタ(ノード間通信のための自己参照)
  # "cluster" = {
  #   description = "Cluster node sync"
  #   ingress_rules = [
  #     { description = "Cluster sync", from_port = 7000, to_port = 7000, protocol = "tcp", source_security_groups = ["cluster"] }
  #   ]
  # }
}

# ===== EC2インスタンス =====
# server_name => { instance_type, subnet_name, security_group_ids, associate_public_ip }
# subnet_name は上記 subnets で定義したキーと一致させる必要があります。
# security_group_ids: SG名のリスト。"common" は常に利用可能です。
# {} を空にするとEC2は作成されません(VPC + SGのみを先行構築したい場合に便利です)。
instances = {
  "server-01" = {
    instance_type       = "t3.micro"
    subnet_name         = "public-a"
    security_group_ids  = ["common"]
    associate_public_ip = true
  }
}

# ===== 機能フラグ =====
enable_nat = false
enable_alb = false

# alb_target_instances = ["server-01"]    # enable_alb = true の場合は必須
